# ─── 应用配置 ─────────────────────────────────────────────
DEBUG=false

# ─── 数据库 ───────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./douyin_crawler.db

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── 视频下载 ─────────────────────────────────────────────
DOWNLOAD_DIR=./videos

# 代理（可选，格式: http://127.0.0.1:7890）
PROXY=

# 抖音 Cookie（从浏览器 F12 复制，用于无水印下载）
# 获取方式：浏览器登录抖音 → F12 → Network → 任意请求 → 复制 Cookie Header
COOKIE=your_douyin_cookie_here

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# ─── Ollama（本地模型，可选）─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2

# ─── AI 提供商：openai | ollama | glm ────────────────────────
AI_PROVIDER=openai

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]
